# Copy this file to `.env` and fill in the values.
# The `.env` file is git-ignored; never commit it.

# DeepL Free API key — used by scripts/translate-books.py and
# scripts/setup-language.py for EU-language translations (da, de, it, fr, pl).
# Sign up at https://www.deepl.com/pro-api and paste the key (with the
# `:fx` suffix for free-tier keys).
DEEPL_API_KEY=your-deepl-key-here:fx
